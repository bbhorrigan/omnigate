{
  "name": "auth-middleware",
  "version": "1.1.0",
  "description": "Authentication middleware for Omnigate",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write .",
    "test": "jest --runInBand",
    "migration:generate": "typeorm-ts-node-commonjs migration:generate",
    "migration:run": "typeorm-ts-node-commonjs migration:run"
  },
  "dependencies": {
    "@simplewebauthn/server": "^8.3.1",
    "express": "^4.21.1",
    "pg": "^8.13.0",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "redis": "^4.7.0",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.5.4",
    "@types/passport": "^1.0.16",
    "@types/passport-github2": "^0.1.12",
    "@types/redis": "^4.0.17",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
